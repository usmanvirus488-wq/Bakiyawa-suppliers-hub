rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'fullName', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.fullName is string && data.fullName.size() <= 100 &&
             (data.phoneNumber == null || (data.phoneNumber is string && data.phoneNumber.size() <= 20)) &&
             (data.addresses == null || (data.addresses is list && data.addresses.size() <= 10));
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'userId', 'items', 'totalAmount', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.orderId is string && data.orderId.size() <= 128 &&
             data.items is list && data.items.size() > 0 && data.items.size() <= 50 &&
             data.status in ['pending', 'processing', 'in transit', 'delivered'] &&
             data.totalAmount is string && data.totalAmount.size() <= 20;
    }

    function isValidFavorite(data) {
      return data.keys().hasAll(['userId', 'productId', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.productId is string && data.productId.size() <= 128;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['reviewId', 'productId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.reviewId is string && data.reviewId.size() <= 128 &&
             data.productId is string && data.productId.size() <= 128 &&
             data.userName is string && data.userName.size() <= 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 500;
    }

    // --- Collections ---

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isEmailVerified() && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'phoneNumber', 'addresses']);
      
      // Favorites Subcollection
      match /favorites/{productId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isEmailVerified() && isValidId(productId) && isValidFavorite(incoming());
        allow delete: if isOwner(userId);
      }
    }

    // Orders
    match /orders/{orderId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isEmailVerified() && isValidId(orderId) && isValidOrder(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
                    incoming().status in ['pending', 'processing', 'in transit', 'delivered'];
    }

    // Reviews
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && isEmailVerified() && isValidId(reviewId) && isValidReview(incoming());
      allow update, delete: if isOwner(existing().userId);
    }
  }
}
