{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User profile data including saved addresses.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "addresses": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "fullName"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order details.",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["pending", "processing", "in transit", "delivered"] 
        },
        "deliveryType": { "type": "string", "enum": ["delivery", "pickup"] },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["orderId", "userId", "items", "totalAmount", "status"]
    },
    "Favorite": {
      "title": "Favorite Product",
      "description": "A product favorited by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId"]
    },
    "Review": {
      "title": "Product Review",
      "description": "User review and rating for a product.",
      "type": "object",
      "properties": {
        "reviewId": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["reviewId", "productId", "userId", "userName", "rating", "comment", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles by ID."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Global orders collection."
    },
    "/users/{userId}/favorites/{productId}": {
      "schema": "Favorite",
      "description": "User-specific favorite products."
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Public product reviews."
    }
  }
}
